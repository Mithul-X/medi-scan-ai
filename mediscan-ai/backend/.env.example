# Copy this file to .env and fill in real values. Never commit .env.

# --- App ---
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# --- Gemini (primary LLM provider) ---
# Get a free key at https://aistudio.google.com/apikey
# Free tier (mid-2026): Gemini 2.5 Flash, ~10-15 RPM, ~250k TPM, ~1000-1500 RPD.
# Gemini 2.0 Flash is END OF LIFE as of June 1, 2026 — do not use it.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_TEXT=gemini-2.5-flash
GEMINI_MODEL_VISION=gemini-2.5-flash

# --- OpenRouter (fallback provider chain, used only if Gemini fails/rate-limits) ---
# Get a free key at https://openrouter.ai/settings/keys (no card required)
# Free models are rate-limited (~20 RPM / ~200 RPD per OpenRouter, subject to change).
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Database ---
# SQLite file on Render's disk. Fine for capstone/demo use; note that
# Render's free tier disk does not persist across redeploys (it does
# persist across restarts within the same deploy).
DATABASE_URL=sqlite+aiosqlite:///./mediscan.db

# --- History scope ---
MAX_SESSIONS_HISTORY=3
MAX_ANALYSES_PER_SESSION=3

# --- Logging ---
LOG_LEVEL=INFO
